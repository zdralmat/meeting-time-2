{
  "name": "meeting-time",
  "version": "1.0.0",
  "description": "Simplified When2Meet clone",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development",
    "dev:worker": "cd worker && npx wrangler dev",
    "dev": "concurrently -n worker,frontend -c cyan,green --kill-others-on-fail \"npm run dev:worker\" \"npm run start\"",
    "build": "webpack --mode production",
    "postbuild": "touch docs/.nojekyll",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.27.0",
    "@babel/preset-env": "^7.27.0",
    "@babel/preset-react": "^7.27.0",
    "babel-loader": "^9.2.0",
    "concurrently": "^10.0.3",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "style-loader": "^4.0.0",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "webpack-dev-server": "^5.2.6"
  }
}
